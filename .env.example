# Academic Anonymous Grader — Environment Configuration
# Copy this file to .env and adjust for your local environment.
# Do not commit .env to version control.
#
# For production / Docker, generate encryption keys:
#   python -c "from security.key_validation import generate_encryption_key, generate_fingerprint_key; print(f'IDENTITY_ENCRYPTION_KEY={generate_encryption_key()}'); print(f'IDENTITY_FINGERPRINT_KEY={generate_fingerprint_key()}')"

# Application environment: development | testing | production
APP_ENV=development

# Debug mode (disable in production)
APP_DEBUG=true

# Database — local SQLite file
DATABASE_URL=sqlite:///data/academic_grader.db

# Encryption keys (REQUIRED for production) — generate with the command above
# IDENTITY_ENCRYPTION_KEY=
# IDENTITY_FINGERPRINT_KEY=
# Phase 12 — Analytics settings
# Minimum group size for privacy-safe display (minimum 3, default 5)
ANALYTICS_MINIMUM_GROUP_SIZE=5
# Default date range for trend reports (days)
ANALYTICS_DEFAULT_DATE_RANGE_DAYS=90
# Maximum rows in analytics exports
ANALYTICS_MAX_EXPORT_ROWS=10000
# Cache TTL for aggregate analytics results (seconds)
ANALYTICS_CACHE_TTL_SECONDS=300
# Enable instructor analytics export
ANALYTICS_ENABLE_INSTRUCTOR_EXPORT=false
# Difficulty threshold (0-1, below this is flagged as difficult)
ANALYTICS_DIFFICULTY_THRESHOLD=0.4
# High zero-score rate threshold (0-1, above this is flagged)
ANALYTICS_HIGH_ZERO_RATE_THRESHOLD=0.3
# Hours after which a grading claim is considered stale
ANALYTICS_STALE_CLAIM_HOURS=4
# Session timeout in minutes
SESSION_TIMEOUT_MINUTES=30

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/academic_grader.log

# Directory paths (relative to project root)
DATA_DIR=data
DATABASE_PATH=data/academic_grader.db
BACKUP_DIR=backups
EXPORT_DIR=exports
LOG_DIR=logs

# Phase 3 HTML import limits
MAX_UPLOAD_SIZE_MB=20
MAX_HTML_TABLES=20
MAX_IMPORT_ROWS=10000
MAX_IMPORT_COLUMNS=500
MAX_CELL_TEXT_LENGTH=1000000

# Phase 4 encryption and fingerprint keys
# Generate with:
#   python -c "import secrets,base64; print('IDENTITY_ENCRYPTION_KEY=' + base64.urlsafe_b64encode(secrets.token_bytes(32)).decode())"
#   python -c "import secrets,base64; print('IDENTITY_FINGERPRINT_KEY=' + base64.urlsafe_b64encode(secrets.token_bytes(32)).decode())"
IDENTITY_ENCRYPTION_KEY=
IDENTITY_FINGERPRINT_KEY=
