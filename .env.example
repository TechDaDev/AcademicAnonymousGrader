# Academic Anonymous Grader — Environment Configuration
# Copy this file to .env and adjust for your local environment.
# Do not commit .env to version control.

# Application
APP_NAME="Academic Anonymous Grader"
APP_ENV=development
APP_DEBUG=true

# Database — local SQLite file
DATABASE_URL=sqlite:///data/academic_grader.db

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/academic_grader.log

# Directory paths (relative to project root)
DATA_DIRECTORY=data
EXPORT_DIRECTORY=exports
UPLOAD_DIRECTORY=uploads
BACKUP_DIRECTORY=backups

# Phase 3 HTML import limits
MAX_UPLOAD_SIZE_MB=20
MAX_HTML_TABLES=20
MAX_IMPORT_ROWS=10000
MAX_IMPORT_COLUMNS=500
MAX_CELL_TEXT_LENGTH=1000000

# Phase 4 encryption and fingerprint keys
# Generate with:
#   python -c "import secrets,base64; print('IDENTITY_ENCRYPTION_KEY=' + base64.urlsafe_b64encode(secrets.token_bytes(32)).decode())"
#   python -c "import secrets,base64; print('IDENTITY_FINGERPRINT_KEY=' + base64.urlsafe_b64encode(secrets.token_bytes(32)).decode())"
IDENTITY_ENCRYPTION_KEY=
IDENTITY_FINGERPRINT_KEY=
